COMPOSE_PROJECT_NAME=pipeline-prod
TZ=Asia/Shanghai

MYSQL_ROOT_PASSWORD=change-root-password
MYSQL_DATABASE=pipeline_management_system
MYSQL_USER=appuser
MYSQL_PASSWORD=change-app-password

POSTGRES_USER=agent
POSTGRES_PASSWORD=change-agent-password
POSTGRES_DB=pipeline_agent

SPRING_PROFILES_ACTIVE=prod
PIPELINE_LOG_DIR=/app/logs
PIPELINE_SSE_TIMEOUT=10m
AGENT_INTERNAL_JWT_SECRET=change-this-shared-secret

AGENT_REQUIRE_INTERNAL_AUTH=true
AGENT_LLM_ENABLED=true
AGENT_LLM_BASE_URL=https://api.moonshot.cn/v1
AGENT_LLM_MODEL=kimi-k2.6
AGENT_LLM_TEMPERATURE=1
AGENT_LLM_API_KEY=replace-with-your-api-key
AGENT_LOG_DIR=/app/logs

FRONTEND_PORT=80
VITE_GEO_CDN_BASE_URL=/geo-cdn/v1
