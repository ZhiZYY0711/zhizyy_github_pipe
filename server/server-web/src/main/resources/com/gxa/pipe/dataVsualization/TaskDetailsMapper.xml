<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gxa.pipe.dataVsualization.taskDetail.TaskDetailsMapper">

    <!-- 结果映射 -->
    <resultMap id="TaskStatusResponseMap" type="com.gxa.pipe.dataVsualization.taskDetail.TaskStatusResponse">
        <result column="status" property="status"/>
        <result column="count" property="count"/>
    </resultMap>

    <!-- 任务数量响应结果映射 -->
    <resultMap id="TaskNumberResponseMap" type="com.gxa.pipe.dataVsualization.taskDetail.TaskNumberResponse">
        <result column="time" property="time"/>
        <result column="count" property="count"/>
    </resultMap>

    <!-- 查询任务状态分布 -->
    <select id="selectTaskStatusDistribution" resultMap="TaskStatusResponseMap">
        SELECT 
            status,
            COUNT(*) as count
        FROM task
        WHERE area_id = #{areaId}
        <if test="startTime != null and startTime != 0">
            AND UNIX_TIMESTAMP(public_time) &gt;= #{startTime}
        </if>
        <if test="endTime != null and endTime != 0">
            AND UNIX_TIMESTAMP(public_time) &lt;= #{endTime}
        </if>
        GROUP BY status
        ORDER BY status
    </select>

    <!-- 查询任务数量趋势 -->
    <select id="selectTaskNumberTrend" resultMap="TaskNumberResponseMap">
        SELECT 
            UNIX_TIMESTAMP(DATE(public_time)) as time,
            COUNT(*) as count
        FROM task
        WHERE area_id = #{areaId}
        <if test="startTime != null and startTime != 0">
            AND UNIX_TIMESTAMP(public_time) &gt;= #{startTime}
        </if>
        <if test="endTime != null and endTime != 0">
            AND UNIX_TIMESTAMP(public_time) &lt;= #{endTime}
        </if>
        GROUP BY time
        ORDER BY time
    </select>

</mapper>