<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gxa.pipe.dataManagement.equipment.EquipmentMapper">

    <!-- 设备响应结果映射 -->
    <resultMap id="EquipmentResponseResultMap" type="com.gxa.pipe.dataManagement.equipment.EquipmentResponse">
        <id column="id" property="id" jdbcType="VARCHAR"/>
        <result column="type" property="type" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="VARCHAR"/>
        <result column="area_name" property="areaName" jdbcType="VARCHAR"/>
        <result column="pipe_name" property="pipeName" jdbcType="VARCHAR"/>
        <result column="last_overhaul_time" property="lastCheck" jdbcType="VARCHAR"/>
        <result column="repairman_name" property="responsible" jdbcType="VARCHAR"/>
    </resultMap>

    <!-- 传感器实体结果映射 -->
    <resultMap id="SensorResultMap" type="com.gxa.pipe.entity.Sensor">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="area_id" property="areaId" jdbcType="BIGINT"/>
        <result column="pipeline_id" property="pipelineId" jdbcType="BIGINT"/>
        <result column="repairman_id" property="repairmanId" jdbcType="BIGINT"/>
        <result column="status" property="status" jdbcType="INTEGER"/>
        <result column="type" property="type" jdbcType="INTEGER"/>
        <result column="last_overhaul_time" property="lastOverhaulTime" jdbcType="TIMESTAMP"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <!-- 基础字段 -->
    <sql id="Base_Column_List">
        s.id, s.area_id, s.pipeline_id, s.repairman_id, s.status, s.type, s.last_overhaul_time, s.create_time, s.update_time
    </sql>

    <!-- 关联查询字段 -->
    <sql id="Join_Column_List">
        s.id, s.type, s.status, s.last_overhaul_time, s.area_id, s.pipeline_id, s.repairman_id, s.create_time, s.update_time,
        CONCAT(a.province, a.city, a.district) as area_name,
        p.name as pipe_name,
        r.name as repairman_name
    </sql>

    <!-- 根据条件查询设备信息 -->
    <select id="selectEquipmentByConditions" resultMap="EquipmentResponseResultMap">
        SELECT
        <include refid="Join_Column_List"/>
        FROM sensor s
        LEFT JOIN area a ON s.area_id = a.id
        LEFT JOIN pipe p ON s.pipeline_id = p.id
        LEFT JOIN repairman r ON s.repairman_id = r.id
        <where>
            <if test="type != null and type != ''">
                AND s.type = #{type}
            </if>
            <if test="status != null and status != ''">
                AND s.status = #{status}
            </if>
            <if test="areaId != null and areaId != ''">
                AND s.area_id = #{areaId}
            </if>
            <if test="pipeId != null and pipeId != ''">
                AND s.pipeline_id = #{pipeId}
            </if>
            <if test="responsible != null and responsible != ''">
                AND s.repairman_id = #{responsible}
            </if>
            <if test="lastCheckStart != null and lastCheckStart != ''">
                AND s.last_overhaul_time &gt;= #{lastCheckStart}
            </if>
            <if test="lastCheckEnd != null and lastCheckEnd != ''">
                AND s.last_overhaul_time &lt;= #{lastCheckEnd}
            </if>
        </where>
        ORDER BY s.create_time DESC
    </select>

    <!-- 根据ID查询设备信息 -->
    <select id="selectEquipmentById" resultMap="EquipmentResponseResultMap">
        SELECT
        <include refid="Join_Column_List"/>
        FROM sensor s
        LEFT JOIN area a ON s.area_id = a.id
        LEFT JOIN pipe p ON s.pipeline_id = p.id
        LEFT JOIN repairman r ON s.repairman_id = r.id
        WHERE s.id = #{id}
    </select>

    <!-- 插入设备信息 -->
    <insert id="insertEquipment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sensor (
            area_id, pipeline_id, repairman_id, status, type, last_overhaul_time, create_time, update_time
        ) VALUES (
            #{areaId}, #{pipelineId}, #{repairmanId}, #{status}, #{type}, #{lastOverhaulTime}, #{createTime}, #{updateTime}
        )
    </insert>

    <!-- 更新设备信息 -->
    <update id="updateEquipment">
        UPDATE sensor
        <set>
            <if test="areaId != null">
                area_id = #{areaId},
            </if>
            <if test="pipelineId != null">
                pipeline_id = #{pipelineId},
            </if>
            <if test="repairmanId != null">
                repairman_id = #{repairmanId},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="type != null">
                type = #{type},
            </if>
            <if test="lastOverhaulTime != null">
                last_overhaul_time = #{lastOverhaulTime},
            </if>
            update_time = #{updateTime}
        </set>
        WHERE id = #{id}
    </update>

    <!-- 批量删除设备信息 -->
    <delete id="deleteEquipmentByIds">
        DELETE FROM sensor WHERE id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 根据ID查询传感器实体 -->
    <select id="selectSensorById" resultMap="SensorResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM sensor s
        WHERE s.id = #{id}
    </select>

    <!-- 统计设备总数 -->
    <select id="countTotal" resultType="int">
        SELECT COUNT(*) FROM sensor
    </select>

    <!-- 统计正常设备数量 -->
    <select id="countNormal" resultType="int">
        SELECT COUNT(*) FROM sensor WHERE status = 0
    </select>

    <!-- 统计故障设备数量 -->
    <select id="countFault" resultType="int">
        SELECT COUNT(*) FROM sensor WHERE status = 1
    </select>

    <!-- 统计维护中设备数量 -->
    <select id="countMaintenance" resultType="int">
        SELECT COUNT(*) FROM sensor WHERE status = 1
    </select>

    <!-- 统计离线设备数量 -->
    <select id="countOffline" resultType="int">
        SELECT COUNT(*) FROM sensor WHERE status = 2
    </select>

    <!-- 验证区域是否存在 -->
    <select id="existsAreaById" resultType="boolean">
        SELECT COUNT(*) > 0 FROM area WHERE id = #{areaId}
    </select>

    <!-- 验证管道是否存在 -->
    <select id="existsPipeById" resultType="boolean">
        SELECT COUNT(*) > 0 FROM pipe WHERE id = #{pipeId}
    </select>

    <!-- 验证检修员是否存在 -->
    <select id="existsRepairmanById" resultType="boolean">
        SELECT COUNT(*) > 0 FROM repairman WHERE id = #{repairmanId}
    </select>

</mapper>