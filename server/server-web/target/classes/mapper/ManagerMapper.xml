<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gxa.pipe.mapper.ManagerMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.gxa.pipe.pojo.entity.Manager">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="username" property="username" jdbcType="VARCHAR"/>
        <result column="password" property="password" jdbcType="VARCHAR"/>
        <result column="name" property="name" jdbcType="VARCHAR"/>
        <result column="phone" property="phone" jdbcType="VARCHAR"/>
        <result column="email" property="email" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="INTEGER"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <!-- 基础字段 -->
    <sql id="Base_Column_List">
        id, username, password, name, phone, email, status, create_time, update_time
    </sql>

    <!-- 根据用户名查询管理员 -->
    <select id="selectByUsername" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM manager
        WHERE username = #{username}
    </select>

    <!-- 根据ID查询管理员 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM manager
        WHERE id = #{id}
    </select>

    <!-- 插入管理员 -->
    <insert id="insert" parameterType="com.gxa.pipe.pojo.entity.Manager" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO manager (username, password, name, phone, email, status, create_time, update_time)
        VALUES (#{username}, #{password}, #{name}, #{phone}, #{email}, #{status}, #{createTime}, #{updateTime})
    </insert>

    <!-- 更新管理员 -->
    <update id="update" parameterType="com.gxa.pipe.pojo.entity.Manager">
        UPDATE manager
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="name != null">name = #{name},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 删除管理员 -->
    <delete id="deleteById">
        DELETE FROM manager WHERE id = #{id}
    </delete>

</mapper>