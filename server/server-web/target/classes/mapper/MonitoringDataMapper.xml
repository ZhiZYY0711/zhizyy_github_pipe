<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gxa.pipe.mapper.MonitoringDataMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.gxa.pipe.pojo.entity.MonitoringData">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="pressure" property="pressure" jdbcType="DECIMAL"/>
        <result column="temperature" property="temperature" jdbcType="DECIMAL"/>
        <result column="traffic" property="traffic" jdbcType="DECIMAL"/>
        <result column="shake" property="shake" jdbcType="DECIMAL"/>
        <result column="data_status" property="dataStatus" jdbcType="INTEGER"/>
        <result column="realtime_picture" property="realtimePicture" jdbcType="VARCHAR"/>
        <result column="sensor_id" property="sensorId" jdbcType="BIGINT"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <!-- 基础字段 -->
    <sql id="Base_Column_List">
        id, pressure, temperature, traffic, shake, data_status, realtime_picture, sensor_id, create_time, update_time
    </sql>

    <!-- 分页查询监测数据 -->
    <select id="selectByPage" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM monitoring_data
        <where>
            <if test="sensorId != null">
                AND sensor_id = #{sensorId}
            </if>
            <if test="startTime != null">
                AND create_time >= #{startTime}
            </if>
            <if test="endTime != null">
                AND create_time &lt;= #{endTime}
            </if>
            <if test="dataStatus != null">
                AND data_status = #{dataStatus}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <!-- 根据ID查询监测数据 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM monitoring_data
        WHERE id = #{id}
    </select>

    <!-- 插入监测数据 -->
    <insert id="insert" parameterType="com.gxa.pipe.pojo.entity.MonitoringData" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO monitoring_data (pressure, temperature, traffic, shake, data_status, realtime_picture, sensor_id, create_time, update_time)
        VALUES (#{pressure}, #{temperature}, #{traffic}, #{shake}, #{dataStatus}, #{realtimePicture}, #{sensorId}, #{createTime}, #{updateTime})
    </insert>

    <!-- 更新监测数据 -->
    <update id="update" parameterType="com.gxa.pipe.pojo.entity.MonitoringData">
        UPDATE monitoring_data
        <set>
            <if test="pressure != null">pressure = #{pressure},</if>
            <if test="temperature != null">temperature = #{temperature},</if>
            <if test="traffic != null">traffic = #{traffic},</if>
            <if test="shake != null">shake = #{shake},</if>
            <if test="dataStatus != null">data_status = #{dataStatus},</if>
            <if test="realtimePicture != null">realtime_picture = #{realtimePicture},</if>
            <if test="sensorId != null">sensor_id = #{sensorId},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 删除监测数据 -->
    <delete id="deleteById">
        DELETE FROM monitoring_data WHERE id = #{id}
    </delete>

    <!-- 统计异常传感器数量 -->
    <select id="countAbnormalSensors" resultType="int">
        SELECT COUNT(DISTINCT sensor_id)
        FROM monitoring_data
        WHERE data_status = 0
        AND create_time >= DATE_SUB(NOW(), INTERVAL 1 DAY)
    </select>

    <!-- 统计传感器总数 -->
    <select id="countTotalSensors" resultType="int">
        SELECT COUNT(DISTINCT sensor_id)
        FROM monitoring_data
    </select>

</mapper>